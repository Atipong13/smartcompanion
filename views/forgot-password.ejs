<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>รีเซ็ตรหัสผ่าน</title>

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Prompt',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;

    background:linear-gradient(135deg,#071018,#0f2027,#1c3b4d);
    color:#fff;
    overflow:hidden;
}

/* glow */
body::before{
    content:"";
    position:fixed;
    width:450px;
    height:450px;
    background:rgba(0,229,255,.12);
    border-radius:50%;
    filter:blur(80px);
    top:-120px;
    left:-120px;
}

body::after{
    content:"";
    position:fixed;
    width:450px;
    height:450px;
    background:rgba(0,255,140,.10);
    border-radius:50%;
    filter:blur(90px);
    bottom:-140px;
    right:-140px;
}

.box{
    width:100%;
    max-width:430px;

    background:rgba(255,255,255,.08);
    border:1px solid rgba(255,255,255,.12);
    backdrop-filter:blur(18px);

    border-radius:28px;
    padding:35px;

    box-shadow:0 20px 60px rgba(0,0,0,.35);
}

/* title */
h2{
    text-align:center;
    font-size:28px;
    margin-bottom:8px;
}

.subtitle{
    text-align:center;
    font-size:14px;
    opacity:.8;
    margin-bottom:22px;
}

/* alert */
.alert-error,
.alert-success{
    padding:12px;
    border-radius:14px;
    margin-bottom:15px;
    text-align:center;
    font-size:14px;
}

.alert-error{
    background:rgba(255,70,70,.18);
    border:1px solid rgba(255,70,70,.35);
}

.alert-success{
    background:rgba(0,255,120,.18);
    border:1px solid rgba(0,255,120,.35);
}

/* input */
input{
    width:100%;
    padding:14px 16px;
    margin-bottom:14px;

    border-radius:14px;
    border:1px solid rgba(255,255,255,.12);

    background:rgba(0,0,0,.25);
    color:#fff;
    outline:none;

    transition:.2s;
}

input:focus{
    border-color:#00e5ff;
    box-shadow:0 0 0 3px rgba(0,229,255,.15);
}

/* button */
button{
    width:100%;
    padding:14px;

    border:none;
    border-radius:14px;

    background:linear-gradient(135deg,#00e5ff,#00c853);
    color:#003344;

    font-weight:700;
    cursor:pointer;

    transition:.2s;
}

button:hover{
    transform:translateY(-2px);
    box-shadow:0 10px 25px rgba(0,229,255,.25);
}

/* note */
.note{
    font-size:12px;
    opacity:.75;
    margin-bottom:15px;
    line-height:1.5;
}

/* back */
.back{
    display:block;
    text-align:center;
    margin-top:18px;
    color:#9ef7ff;
    text-decoration:none;
    font-size:14px;
}

.back:hover{
    opacity:.8;
}
/* OTP */
.otp-container{
    display:flex;
    justify-content:center;
    gap:10px;
    margin-bottom:18px;
}

.otp-input{
    width:52px;
    height:60px;

    text-align:center;
    font-size:24px;
    font-weight:700;

    border-radius:14px;
    border:1px solid rgba(255,255,255,.15);

    background:rgba(0,0,0,.25);
    color:#fff;

    outline:none;
    transition:.2s;
}

.otp-input:focus{
    border-color:#00e5ff;
    box-shadow:0 0 0 3px rgba(0,229,255,.18);
}

.otp-input.filled{
    border-color:#00c853;
}
</style>
</head>

<body>

<div class="box">

    <h2>🔑 รีเซ็ตรหัสผ่าน</h2>
    <div class="subtitle">SmartCompanion</div>

    <% if(error){ %>
        <div class="alert-error"><%= error %></div>
    <% } %>

    <% if(success){ %>
        <div class="alert-success"><%= success %></div>
    <% } %>

    <% if(step === 1){ %>

        <p class="subtitle">กรอกเบอร์โทรเพื่อรับ OTP</p>

        <form method="POST" action="/forgot-password">

            <input type="text"
                name="phone"
                placeholder="📱 เบอร์โทรศัพท์"
                maxlength="10"
                pattern="[0-9]{10}"
                inputmode="numeric"
                oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                required
            >

            <button>ส่ง OTP</button>

        </form>

    <% } %>

    <% if(step === 2){ %>

        <p class="subtitle">กรอก OTP และตั้งรหัสใหม่</p>

        <form method="POST" action="/forgot-password/reset">

           <div class="otp-container">
    <input type="text" class="otp-input" maxlength="1" inputmode="numeric">
    <input type="text" class="otp-input" maxlength="1" inputmode="numeric">
    <input type="text" class="otp-input" maxlength="1" inputmode="numeric">
    <input type="text" class="otp-input" maxlength="1" inputmode="numeric">
    <input type="text" class="otp-input" maxlength="1" inputmode="numeric">
    <input type="text" class="otp-input" maxlength="1" inputmode="numeric">
</div>

<input type="hidden" name="otp" id="otp" required>

            
            <div class="note">
                รหัสผ่าน ต้องมีตัวอักษรA-zและตัวเลข อย่างน้อย 8 ตัว
            </div>
<input
    type="password"
    name="password"
    placeholder="🔒 รหัสผ่านใหม่"
    minlength="8"
    maxlength="20"
    oninput="this.value=this.value.replace(/[^A-Za-z0-9]/g,'')"
    required
>

         <input
    type="password"
    name="confirmPassword"
    placeholder="🔒 ยืนยันรหัสผ่าน"
    minlength="8"
    maxlength="20"
    oninput="this.value=this.value.replace(/[^A-Za-z0-9]/g,'')"
    required
>

            <button>รีเซ็ตรหัสผ่าน</button>

        </form>

    <% } %>

    <a href="/login" class="back">← กลับเข้าสู่ระบบ</a>

</div>
<script>

const inputs = document.querySelectorAll(".otp-input");
const hiddenOTP = document.getElementById("otp");

inputs.forEach((input,index)=>{

    input.addEventListener("input",e=>{

        input.value=input.value.replace(/[^0-9]/g,'');

        if(input.value){
            input.classList.add("filled");

            if(index<5){
                inputs[index+1].focus();
            }
        }else{
            input.classList.remove("filled");
        }

        hiddenOTP.value=[...inputs].map(i=>i.value).join("");

    });

    input.addEventListener("keydown",e=>{

        if(e.key==="Backspace" && !input.value && index>0){
            inputs[index-1].focus();
        }

    });

    input.addEventListener("paste",e=>{

        e.preventDefault();

        const data=(e.clipboardData.getData("text") || "")
                    .replace(/\D/g,"")
                    .substring(0,6);

        data.split("").forEach((num,i)=>{

            if(inputs[i]){
                inputs[i].value=num;
                inputs[i].classList.add("filled");
            }

        });

        hiddenOTP.value=data;

        if(data.length<6){
            inputs[data.length].focus();
        }else{
            inputs[5].focus();
        }

    });

});

</script>
</body>
</html>