<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>รีเซ็ตรหัสผ่าน</title>

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Prompt',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;

    background:linear-gradient(135deg,#071018,#0f2027,#1c3b4d);
    color:#fff;
    overflow:hidden;
}

/* glow */
body::before{
    content:"";
    position:fixed;
    width:450px;
    height:450px;
    background:rgba(0,229,255,.12);
    border-radius:50%;
    filter:blur(80px);
    top:-120px;
    left:-120px;
}

body::after{
    content:"";
    position:fixed;
    width:450px;
    height:450px;
    background:rgba(0,255,140,.10);
    border-radius:50%;
    filter:blur(90px);
    bottom:-140px;
    right:-140px;
}

.box{
    width:100%;
    max-width:430px;

    background:rgba(255,255,255,.08);
    border:1px solid rgba(255,255,255,.12);
    backdrop-filter:blur(18px);

    border-radius:28px;
    padding:35px;

    box-shadow:0 20px 60px rgba(0,0,0,.35);
}

/* title */
h2{
    text-align:center;
    font-size:28px;
    margin-bottom:8px;
}

.subtitle{
    text-align:center;
    font-size:14px;
    opacity:.8;
    margin-bottom:22px;
}

/* alert */
.alert-error,
.alert-success{
    padding:12px;
    border-radius:14px;
    margin-bottom:15px;
    text-align:center;
    font-size:14px;
}

.alert-error{
    background:rgba(255,70,70,.18);
    border:1px solid rgba(255,70,70,.35);
}

.alert-success{
    background:rgba(0,255,120,.18);
    border:1px solid rgba(0,255,120,.35);
}

/* input */
input{
    width:100%;
    padding:14px 16px;
    margin-bottom:14px;

    border-radius:14px;
    border:1px solid rgba(255,255,255,.12);

    background:rgba(0,0,0,.25);
    color:#fff;
    outline:none;

    transition:.2s;
}

input:focus{
    border-color:#00e5ff;
    box-shadow:0 0 0 3px rgba(0,229,255,.15);
}

/* button */
button{
    width:100%;
    padding:14px;

    border:none;
    border-radius:14px;

    background:linear-gradient(135deg,#00e5ff,#00c853);
    color:#003344;

    font-weight:700;
    cursor:pointer;

    transition:.2s;
}

button:hover{
    transform:translateY(-2px);
    box-shadow:0 10px 25px rgba(0,229,255,.25);
}

/* note */
.note{
    font-size:12px;
    opacity:.75;
    margin-bottom:15px;
    line-height:1.5;
}

/* back */
.back{
    display:block;
    text-align:center;
    margin-top:18px;
    color:#9ef7ff;
    text-decoration:none;
    font-size:14px;
}

.back:hover{
    opacity:.8;
}

</style>
</head>

<body>

<div class="box">

    <h2>🔑 รีเซ็ตรหัสผ่าน</h2>
    <div class="subtitle">SmartCompanion</div>

    <% if(error){ %>
        <div class="alert-error"><%= error %></div>
    <% } %>

    <% if(success){ %>
        <div class="alert-success"><%= success %></div>
    <% } %>

    <% if(step === 1){ %>

        <p class="subtitle">กรอกเบอร์โทรเพื่อรับ OTP</p>

        <form method="POST" action="/forgot-password">

            <input type="text"
                name="phone"
                placeholder="📱 เบอร์โทรศัพท์"
                maxlength="10"
                pattern="[0-9]{10}"
                inputmode="numeric"
                oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                required
            >

            <button>ส่ง OTP</button>

        </form>

    <% } %>

    <% if(step === 2){ %>

        <p class="subtitle">กรอก OTP และตั้งรหัสใหม่</p>

        <form method="POST" action="/forgot-password/reset">

            <input type="text"
                name="otp"
                placeholder="🔢 OTP 6 หลัก"
                maxlength="6"
                pattern="[0-9]{6}"
                inputmode="numeric"
                required
            >

            
            <div class="note">
                รหัสผ่าน ต้องมีตัวอักษรA-zและตัวเลข อย่างน้อย 8 ตัว
            </div>
<input type="password"
                name="password"
                placeholder="🔒 รหัสผ่านใหม่"
                minlength="6"
                required
            >

            <input type="password"
                name="confirmPassword"
                placeholder="🔒 ยืนยันรหัสผ่าน"
                required
            >

            <button>รีเซ็ตรหัสผ่าน</button>

        </form>

    <% } %>

    <a href="/login" class="back">← กลับเข้าสู่ระบบ</a>

</div>

</body>
</html>