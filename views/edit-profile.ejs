<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>สมัครอาสา | SmartCompanion</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>/* =========================
   FONT + RESET
========================= */
*{
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  margin:0;
  min-height:100vh;

  /* พื้นหลังขาว */
  background:#f4f8fc;

  display:flex;
  justify-content:center;
  align-items:center;

  overflow:hidden;
  position:relative;
}

/* =========================
   LIGHT BACKGROUND EFFECT
========================= */

/* แสงฟุ้งซ้าย */
body::before{
  content:"";
  position:fixed;
  width:500px;
  height:500px;
  background:
    radial-gradient(circle,
      rgba(0,229,255,.25),
      transparent 70%);

  top:-180px;
  left:-120px;

  animation:float1 8s ease-in-out infinite;
}

/* แสงฟุ้งขวา */
body::after{
  content:"";
  position:fixed;
  width:500px;
  height:500px;

  background:
    radial-gradient(circle,
      rgba(123,97,255,.18),
      transparent 70%);

  bottom:-180px;
  right:-120px;

  animation:float2 10s ease-in-out infinite;
}

@keyframes float1{
  0%{transform:translateY(0);}
  50%{transform:translateY(35px);}
  100%{transform:translateY(0);}
}

@keyframes float2{
  0%{transform:translateY(0);}
  50%{transform:translateY(-30px);}
  100%{transform:translateY(0);}
}

/* =========================
   CONTAINER
========================= */

.container{
  position:relative;

  width:100%;
  max-width:920px;

  padding:45px;

  border-radius:30px;

  background:rgba(255,255,255,0.92);

  backdrop-filter:blur(12px);

  overflow:hidden;

  z-index:2;

  box-shadow:
    0 20px 50px rgba(0,0,0,.08);
}

/* เส้นไฟวิ่งรอบกรอบ */
.container::before{
  content:"";
  position:absolute;
  inset:-3px;

  border-radius:34px;

  background:
    conic-gradient(
      from 0deg,

      transparent 0deg,
      transparent 40deg,

      #00e5ff 90deg,
      #4facfe 140deg,
      #7b61ff 200deg,

      transparent 260deg,
      transparent 360deg
    );

animation:borderRotate 12s linear infinite;
  z-index:-2;

  filter:blur(1px);
}

/* ทำให้เหลือแค่กรอบ */
.container::after{
  content:"";
  position:absolute;

  inset:3px;

  border-radius:28px;

  background:#ffffff;

  z-index:-1;
}

/* วงแสงฟุ้ง */
.glow{
  position:absolute;

  inset:-25px;

  border-radius:40px;

  background:
    conic-gradient(
      from 0deg,
      rgba(0,229,255,.45),
      rgba(79,172,254,.35),
      rgba(123,97,255,.35),
      rgba(0,229,255,.45)
      
    );

  filter:blur(35px);

  animation:borderRotate 8s linear infinite;

  z-index:-3;
}

/* หมุน */
@keyframes borderRotate{
  from{
    transform:rotate(0turn);
  }

  to{
    transform:rotate(1turn);
  }
}

/* =========================
   TITLE
========================= */

h2{
  text-align:center;
  margin-bottom:30px;

  font-size:34px;
  font-weight:700;

  color:#1d2b36;
}

/* =========================
   GRID
========================= */

.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:18px;
}

.full{
  grid-column:1/3;
}

/* =========================
   LABEL
========================= */

label{
  font-size:14px;
  color:#5b6875;
  font-weight:500;
}

/* =========================
   INPUT
========================= */

input,
select,
textarea{
  width:100%;

  padding:14px;

  border-radius:16px;

  border:1px solid #dbe7f0;

  margin-top:7px;

  background:#f8fbff;

  color:#1f2937;

  font-size:15px;

  outline:none;

  transition:.3s;
}

textarea{
  resize:none;
}

input:focus,
select:focus,
textarea:focus{

  border-color:#ff0000;

  background:#fff;

  box-shadow:
    0 0 15px rgba(0,217,255,.18);
}

input::placeholder{
  color:#9aa7b5;
}

/* =========================
   ERROR
========================= */

.err{
  font-size:12px;
  color:#ff6b6b;
  margin-top:4px;
}

/* =========================
   SKILLS
========================= */

.skills{
  display:flex;
  gap:20px;
  margin-top:10px;
  flex-wrap:wrap;
  color:#4b5563;
}

/* =========================
   BUTTON
========================= */

.button-group{
  margin-top:35px;
  display:flex;
  gap:15px;
}

button{
  flex:1;

  padding:15px;

  border:none;

  border-radius:16px;

  background:
    linear-gradient(
      120deg,
      #ff0000,
      #000000
    );

  color:#fff;

  font-size:16px;
  font-weight:600;

  cursor:pointer;

  transition:.3s;
}

button:hover{
  transform:translateY(-2px);

  box-shadow:
    0 10px 25px rgba(79,172,254,.30);
}

/* ปุ่มกลับ */
.back{
  flex:1;

  padding:15px;

  border-radius:16px;

  border:2px solid #00d9ff;

  text-align:center;

  color:#00a8d6;

  background:#fff;

  text-decoration:none;

  font-weight:600;

  transition:.3s;
}

.back:hover{
  background:#f0fbff;

  box-shadow:
    0 0 18px rgba(0,217,255,.18);
}

/* =========================
   SUCCESS
========================= */

.success{
  text-align:center;
  margin-bottom:18px;
  padding:14px;

  border-radius:14px;

  background:
    rgba(0,255,200,0.12);

  color:#00b894;

  font-weight:600;

  border:1px solid rgba(0,255,200,0.25);
}

/* =========================
   MESSAGE TOP
========================= */

#msgTop{
  display:none;

  text-align:center;

  margin-bottom:18px;

  padding:14px;

  border-radius:14px;

  background:#ffffff;

  color:#ff0000;

  font-weight:600;
}

/* =========================
   PASSWORD
========================= */

.input-group{
  margin-bottom:15px;
}

.password-wrapper{
  position:relative;
  width:100%;
}

.password-wrapper input{
  padding-right:45px;
}

.eye{
  position:absolute;
  right:14px;
  top:50%;

  transform:translateY(-50%);

  cursor:pointer;

  font-size:18px;

  color:#7b8794;
}
</style>
</head>

<body>

<div class="container">
<h2>
<%= user ? 'แก้ไขข้อมูลอาสา' : 'สมัครอาสา SmartCompanion' %>
</h2>

<div id="msgTop"></div>
<% if (success) { %>
  <div class="success"><%= success %></div>
<% } %>

<form
  id="volForm"
  method="POST"
  action="<%= user ? '/volunteer/edit-profile' : '/volunteer/register' %>"
  onsubmit="return validate()"
>
<input
  type="hidden"
  name="lineid"
  value="<%= user ? user.lineid : (typeof lineid !== 'undefined' ? lineid : '') %>"
>
<div class="grid">

<div>
<label>ชื่อจริง</label>
<!-- ชื่อ -->
<input
  type="text"
  id="name"
  name="name"
  value="<%= user ? user.name : '' %>"
  pattern="[ก-๙\s]+"
  oninput="this.value = this.value.replace(/[^ก-๙\s]/g,'')"
  required
>
<div class="err" id="err_name"></div>
</div>

<div>
<label>เบอร์โทร</label>
<!-- เบอร์ -->
<input
  type="text"
  id="phone"
  name="phone"
  value="<%= user ? user.phone : '' %>"
  maxlength="10"
  pattern="[0-9]{10}"
  inputmode="numeric"
  oninput="this.value = this.value.replace(/[^0-9]/g, '')"
  required
>
<div class="err" id="err_phone"></div>
</div>
<div class="input-group">
  <label>รหัสผ่าน</label>
  <div class="password-wrapper">
  <input
  type="password"
  id="password"
  name="password"
  <%= user ? '' : 'required' %>
>
    <span class="eye" onclick="togglePassword('password', this)">👁</span>
  </div>
  <div class="err" id="err_pass"></div>
</div>

<div class="input-group">
  <label>ยืนยันรหัสผ่าน</label>
  <div class="password-wrapper">
<input
  type="password"
  id="confirm"
  name="confirm"
  <%= user ? '' : 'required' %>
>
    <span class="eye" onclick="togglePassword('confirm', this)">👁</span>
  </div>
  <div class="err" id="err_confirm"></div>
</div>

<div>
<label>อายุ</label>
<!-- อายุ -->
<input
  type="text"
  id="age"
  name="age"
  value="<%= user ? user.age : '' %>"
  maxlength="2"
  inputmode="numeric"
  pattern="[0-9]{2}"
  oninput="this.value=this.value.replace(/[^0-9]/g,'')"
  required
>
<div class="err" id="err_age"></div>
</div>

<div>
<label>พื้นที่</label><select id="area" name="area">

<option value="">เลือกพื้นที่</option>

<option value="บ้านง่อง"
<%= user && user.area === 'บ้านง่อง' ? 'selected' : '' %>>
บ้านง่อง
</option>

<option value="อำเภอเมืองร้อยเอ็ด"
<%= user && user.area === 'อำเภอเมืองร้อยเอ็ด' ? 'selected' : '' %>>
อำเภอเมืองร้อยเอ็ด
</option>

</select>
<div class="err" id="err_area"></div>
</div>
<div class="full">
<label>ความสามารถ</label>

<div class="skills">

<label>
<input type="checkbox"
name="skill[]"
value="ดูแลผู้สูงอายุ"
<%= user && user.skill &&
user.skill.includes('ดูแลผู้สูงอายุ')
? 'checked' : '' %>>
ดูแลผู้สูงอายุ
</label>

<label>
<input type="checkbox"
name="skill[]"
value="พาไปโรงพยาบาล"
<%= user && user.skill &&
user.skill.includes('พาไปโรงพยาบาล')
? 'checked' : '' %>>
พาไปโรงพยาบาล
</label>

<label>
<input type="checkbox"
name="skill[]"
value="ซื้อของ"
<%= user && user.skill &&
user.skill.includes('ซื้อของ')
? 'checked' : '' %>>
ซื้อของ
</label>

</div>

<div class="err" id="err_skill"></div>
</div>

<div class="full">
<label>ประสบการณ์</label>

<textarea
id="experience"
name="experience"
rows="3"><%= user ? user.experience : '' %></textarea>

<div class="err" id="err_exp"></div>
</div>
<div class="button-group">

<button type="submit" id="btnSubmit">
<%= user ? '💾 บันทึกข้อมูล' : 'สมัครอาสา' %>
</button>

<% if(user){ %>

<a href="/volunteer" class="back">
← กลับหน้าอาสา
</a>

<% } else { %>

<a href="/login" class="back">
กลับหน้า login
</a>

<% } %>

</div>
<script>

const form = document.getElementById("volForm");
const passwordInput = document.getElementById("password");
const confirmInput = document.getElementById("confirm");

/* ===============================
   🔒 บล็อกภาษาไทยตอนพิมพ์
================================ */
passwordInput.addEventListener("input", function() {
  this.value = this.value.replace(/[^A-Za-z0-9]/g, '');
});

confirmInput.addEventListener("input", function() {
  this.value = this.value.replace(/[^A-Za-z0-9]/g, '');
});

function togglePassword(inputId, eyeElement) {
  const input = document.getElementById(inputId);

  if (input.type === "password") {
    input.type = "text";
    eyeElement.textContent = "🙈"; // เปลี่ยนเป็นตาปิด
  } else {
    input.type = "password";
    eyeElement.textContent = "👁"; // เปลี่ยนกลับ
  }
}
/* ===============================
   ✅ VALIDATE
================================ */
function validate(){
let ok=true;
document.querySelectorAll(".err").forEach(e=>e.innerText="");

const name=nameVal("name");
const phone=nameVal("phone");
const pass=nameVal("password");
const confirm=nameVal("confirm");
const age=nameVal("age");
const area=nameVal("area");
const exp=nameVal("experience");

// ชื่อไทยเท่านั้น
if(!/^[ก-๙\s]+$/.test(name)){
err("err_name","กรอกชื่อภาษาไทยเท่านั้น"); ok=false;
}

// เบอร์ 10 หลักขึ้นต้น 0
if(!/^0[0-9]{9}$/.test(phone)){
err("err_phone","เบอร์ต้อง 10 หลักขึ้นต้น 0"); ok=false;
}

// อายุ 2 หลัก
if(!/^[0-9]{2}$/.test(age)){
err("err_age","อายุต้องเป็นตัวเลข 2 หลัก"); ok=false;
}

// รหัสผ่าน A-Z a-z 0-9 อย่างน้อย 8 ตัว
if(pass && !/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)[A-Za-z\d]{8,}$/.test(pass)){
    err("err_pass","ต้องมี A-Z a-z และตัวเลข อย่างน้อย 8 ตัว"); ok=false;
}

if(pass && pass !== confirm){
    err("err_confirm","รหัสไม่ตรง"); ok=false;
}

if(!area){
err("err_area","เลือกพื้นที่"); ok=false;
}

if(document.querySelectorAll("input[name='skill[]']:checked").length===0){
err("err_skill","เลือกความสามารถ"); ok=false;
}

if(!exp){
err("err_exp","กรอกประสบการณ์"); ok=false;
}

return ok;
}

function nameVal(id){return document.getElementById(id).value.trim();}
function err(id,msg){document.getElementById(id).innerText=msg;}

</script>

</body>
</html>