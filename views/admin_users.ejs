<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>จัดการผู้ใช้ | SmartCompanion</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  background:#0f172a;
  color:#fff;
  display:flex;
  min-height:100vh;
}

/* SIDEBAR */

.sidebar{
  width:260px;
  background:rgba(15,23,42,.95);
  border-right:1px solid rgba(255,255,255,.05);
  backdrop-filter:blur(18px);
  padding:30px 20px;
}

.logo{
  font-size:24px;
  font-weight:600;
  margin-bottom:40px;
}

.sidebar a{
  display:flex;
  align-items:center;
  gap:12px;
  color:#cbd5e1;
  text-decoration:none;
  padding:14px 16px;
  border-radius:16px;
  margin-bottom:10px;
  transition:.25s;
}

.sidebar a:hover{
  background:#2563eb;
  color:#fff;
  transform:translateX(4px);
}

/* MAIN */

.main{
  flex:1;
  padding:30px;
}

/* TOPBAR */

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30px;
}

.topbar h1{
  font-size:30px;
}

/* SEARCH */

.search-box{
  margin-bottom:25px;
}

.search-box input{
  width:100%;
  padding:14px 18px;
  border:none;
  border-radius:18px;
  background:rgba(255,255,255,.06);
  color:#fff;
  font-size:14px;
  outline:none;
}

.search-box input::placeholder{
  color:#94a3b8;
}

/* KPI */

.kpi-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:30px;
}

.kpi-card{
  background:linear-gradient(
    135deg,
    rgba(37,99,235,.95),
    rgba(59,130,246,.7)
  );

  border-radius:24px;
  padding:25px;

  position:relative;
  overflow:hidden;

  box-shadow:
    0 15px 40px rgba(37,99,235,.25);

  transition:.25s;
}

.kpi-card:hover{
  transform:translateY(-5px);
}

.kpi-card::before{
  content:'';
  position:absolute;
  width:150px;
  height:150px;
  background:rgba(255,255,255,.08);
  border-radius:50%;
  top:-40px;
  right:-40px;
}

.kpi-title{
  color:#dbeafe;
  font-size:14px;
}

.kpi-value{
  font-size:38px;
  margin-top:10px;
  font-weight:600;
}

/* USERS GRID */

.users-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:24px;
}

/* CARD */

.card{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.06);

  backdrop-filter:blur(18px);

  border-radius:24px;
  padding:25px;

  transition:.25s;
}

.card:hover{
  transform:translateY(-5px);
  box-shadow:0 20px 40px rgba(0,0,0,.25);
}

/* USER TOP */

.user-top{
  display:flex;
  align-items:center;
  gap:16px;
  margin-bottom:20px;
}

.avatar{
  width:64px;
  height:64px;
  border-radius:50%;
  background:linear-gradient(
    135deg,
    #3b82f6,
    #60a5fa
  );

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:24px;
  font-weight:600;
}

.user-info h3{
  margin-bottom:5px;
}

.user-info p{
  color:#94a3b8;
  font-size:13px;
}

/* ROLE */

.role{
  display:inline-block;
  padding:6px 14px;
  border-radius:999px;
  font-size:12px;
  font-weight:600;
  margin-top:10px;
}

.elder{
  background:#2563eb33;
  color:#60a5fa;
}

.volunteer{
  background:#16a34a33;
  color:#4ade80;
}

/* DETAILS */

.details{
  margin-top:18px;
  padding-top:16px;
  border-top:1px solid rgba(255,255,255,.08);
  display:flex;
  flex-direction:column;
  gap:10px;
  font-size:14px;
  color:#cbd5e1;
}

.details .row{
  display:flex;
  align-items:flex-start;
  gap:10px;
}

.details .row .ico{
  flex-shrink:0;
  width:28px;
  height:28px;
  border-radius:8px;
  background:rgba(255,255,255,.06);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:13px;
}

.details .row .val-label{
  display:block;
  color:#94a3b8;
  font-size:11px;
  letter-spacing:.03em;
  text-transform:uppercase;
  margin-bottom:2px;
}

.details .row .val{
  color:#e2e8f0;
}

.details .row .val.empty-val{
  color:#64748b;
  font-style:italic;
}

/* BUTTONS */

.btns{
  display:flex;
  gap:12px;
  margin-top:22px;
}

.btn{
  flex:1;
  border:none;
  padding:12px;
  border-radius:14px;
  cursor:pointer;
  font-size:14px;
  font-weight:500;
  transition:.25s;
}

.edit{
  background:#2563eb;
  color:#fff;
}

.edit:hover{
  background:#1d4ed8;
}

.delete{
  background:#dc2626;
  color:#fff;
}

.delete:hover{
  background:#b91c1c;
}

/* EMPTY */

.empty{
  text-align:center;
  margin-top:100px;
  color:#94a3b8;
  font-size:18px;
}

/* MOBILE */

@media(max-width:1000px){

  .sidebar{
    display:none;
  }

}

</style>
</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

  <div class="logo">
    🛠 SmartCompanion
  </div>

  <a href="/admin">📋 Dashboard</a>
  <a href="/admin/working">🟢 เคสกำลังทำ</a>
  <a href="/admin/volunteers">👥 อนุมัติอาสา</a>
  <a href="/admin/users">👤 จัดการผู้ใช้</a>
  <a href="/admin/reports">📊 รายงาน</a>
  <a href="/logout">🚪 ออกจากระบบ</a>

</div>

<!-- MAIN -->

<div class="main">

  <!-- TOPBAR -->

  <div class="topbar">

    <h1>
      👤 User Management
    </h1>

  </div>

  <!-- SEARCH -->

  <div class="search-box">

    <input
      type="text"
      id="searchInput"
      placeholder="ค้นหาชื่อผู้ใช้..."
    >

  </div>

  <!-- KPI -->

  <div class="kpi-grid">

    <div class="kpi-card">
      <div class="kpi-title">
        ผู้ใช้ทั้งหมด
      </div>

      <div class="kpi-value">
        <%= users.length %>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">
        อาสาสมัคร
      </div>

      <div class="kpi-value">
        <%= users.filter(
          u=>u.role==='volunteer'
        ).length %>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">
        ผู้สูงอายุ
      </div>

      <div class="kpi-value">
        <%= users.filter(
          u=>u.role==='elder'
        ).length %>
      </div>
    </div>

  </div>

  <!-- USERS -->

  <% if(users.length === 0){ %>

    <div class="empty">
      ไม่มีผู้ใช้ในระบบ
    </div>

  <% } %>

  <div class="users-grid" id="usersGrid">

    <% users.forEach(u=>{ %>

      <div
        class="card user-card"
        data-name="<%= u.name.toLowerCase() %>"
      >

        <!-- TOP -->

        <div class="user-top">

          <div class="avatar">
            <%= u.name.charAt(0) %>
          </div>

          <div class="user-info">

            <h3>
              <%= u.name %>
            </h3>

            <p>
              ID: <%= u.id %>
            </p>

            <% if(u.role === 'elder'){ %>

              <span class="role elder">
                ผู้สูงอายุ
              </span>

            <% } %>

            <% if(u.role === 'volunteer'){ %>

              <span class="role volunteer">
                อาสาสมัคร
              </span>

            <% } %>

          </div>

        </div>

        <!-- DETAILS -->

        <div class="details">

          <div class="row">
            <div class="ico">📞</div>
            <div>
              <span class="val-label">โทร</span>
              <span class="val <%= u.phone ? '' : 'empty-val' %>"><%= u.phone || '-' %></span>
            </div>
          </div>

          <div class="row">
            <div class="ico">📍</div>
            <div>
              <span class="val-label">พื้นที่</span>
              <span class="val <%= u.area ? '' : 'empty-val' %>"><%= u.area || '-' %></span>
            </div>
          </div>

          <div class="row">
            <div class="ico">🎂</div>
            <div>
              <span class="val-label">อายุ</span>
              <span class="val <%= u.age ? '' : 'empty-val' %>"><%= u.age || '-' %></span>
            </div>
          </div>

          <% if(u.skill){ %>
          <div class="row">
            <div class="ico">🩺</div>
            <div>
              <span class="val-label">ความสามารถ</span>
              <span class="val"><%= u.skill %></span>
            </div>
          </div>
          <% } %>

          <div class="row">
            <div class="ico">📝</div>
            <div>
              <span class="val-label">ประสบการณ์</span>
              <span class="val <%= u.experience ? '' : 'empty-val' %>"><%= u.experience || '-' %></span>
            </div>
          </div>

        </div>

        <!-- BUTTONS -->

        <div class="btns">

          <a
            href="/admin/edit-user/<%= u.id %>"
            style="flex:1;"
          >
            <button class="btn edit">
              แก้ไข
            </button>
          </a>

          <form
            action="/admin/delete-user/<%= u.id %>"
            method="POST"
            style="flex:1;"
          >

            <button
              class="btn delete"
              onclick="return confirm(
                'ต้องการลบผู้ใช้หรือไม่?'
              )"
            >
              ลบ
            </button>

          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>

<script>

/* SEARCH */

const searchInput =
document.getElementById('searchInput');

const cards =
document.querySelectorAll('.user-card');

searchInput.addEventListener('keyup',()=>{

  const keyword =
  searchInput.value.toLowerCase();

  cards.forEach(card=>{

    const name =
    card.dataset.name;

    if(name.includes(keyword)){

      card.style.display='block';

    }else{

      card.style.display='none';

    }

  });

});

</script>

</body>
</html>
