<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>SmartCompanion | เคสของฉัน</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  min-height:100vh;
  background:
    radial-gradient(circle at top left,#00e5ff22,transparent 30%),
    radial-gradient(circle at bottom right,#00ff9522,transparent 30%),
    linear-gradient(135deg,#07111f,#0f2027,#1d3a45);
  color:#fff;
  overflow-x:hidden;
}

/* =========================
   GLOW EFFECT
========================= */

body::before{
  content:"";
  position:fixed;
  width:400px;
  height:400px;
  border-radius:50%;
  background:#00e5ff22;
  top:-120px;
  left:-120px;
  filter:blur(80px);
}

body::after{
  content:"";
  position:fixed;
  width:500px;
  height:500px;
  border-radius:50%;
  background:#00ff9520;
  bottom:-180px;
  right:-180px;
  filter:blur(100px);
}

/* =========================
   HEADER
========================= */

.header{
  position:sticky;
  top:0;
  z-index:100;

  padding:28px 20px;

  backdrop-filter:blur(18px);
  background:rgba(255,255,255,.06);

  border-bottom:1px solid rgba(255,255,255,.08);

  text-align:center;
}

.header h2{
  font-size:34px;
  font-weight:700;
}

.header p{
  margin-top:10px;
  color:#bdefff;
  font-size:15px;
}

/* =========================
   CONTAINER
========================= */

.container{
  max-width:1100px;
  margin:auto;
  padding:40px 20px;
}

/* =========================
   TOPBAR
========================= */

.top-tools{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30px;
  gap:15px;
  flex-wrap:wrap;
}

/* BACK */

.back-link{
  display:inline-flex;
  align-items:center;
  gap:8px;

  text-decoration:none;

  padding:12px 18px;

  border-radius:14px;

  background:rgba(255,255,255,.08);

  color:#bffcff;

  border:1px solid rgba(255,255,255,.08);

  transition:.25s;
}

.back-link:hover{
  transform:translateY(-3px);

  background:rgba(0,255,255,.12);

  box-shadow:
    0 8px 25px rgba(0,255,255,.18);
}

/* STATS */

.stats{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
}

.stat-card{
  min-width:180px;

  background:rgba(255,255,255,.08);

  backdrop-filter:blur(15px);

  border-radius:22px;

  padding:22px;

  border:1px solid rgba(255,255,255,.08);

  box-shadow:
    0 10px 30px rgba(0,0,0,.25);
}

.stat-title{
  font-size:14px;
  color:#b9e9ff;
}

.stat-value{
  margin-top:8px;
  font-size:32px;
  font-weight:700;
}

/* =========================
   EMPTY
========================= */

.empty{
  text-align:center;

  padding:70px 30px;

  border-radius:30px;

  background:rgba(255,255,255,.08);

  backdrop-filter:blur(18px);

  border:1px solid rgba(255,255,255,.08);

  font-size:20px;

  color:#dffcff;
}

/* =========================
   CARD
========================= */

.case-card{
  position:relative;

  background:rgba(255,255,255,.08);

  backdrop-filter:blur(16px);

  border-radius:30px;

  padding:32px;

  margin-bottom:30px;

  overflow:hidden;

  border:1px solid rgba(255,255,255,.08);

  transition:.35s;

  box-shadow:
    0 15px 40px rgba(0,0,0,.3);
}

.case-card:hover{
  transform:translateY(-6px);

  box-shadow:
    0 25px 60px rgba(0,0,0,.4);
}

/* glow */

.case-card::before{
  content:"";

  position:absolute;

  width:220px;
  height:220px;

  background:rgba(0,255,255,.08);

  border-radius:50%;

  top:-80px;
  right:-80px;

  filter:blur(40px);
}

/* =========================
   TOP
========================= */

.card-top{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:20px;
  flex-wrap:wrap;
}

.case-title{
  font-size:26px;
  font-weight:600;
}

/* STATUS */

.status-badge{
  padding:10px 18px;

  border-radius:999px;

  font-size:13px;
  font-weight:700;
}

.status-badge.accepted{
  background:#ffb300;
  color:#fff;

  box-shadow:
    0 0 18px rgba(255,179,0,.3);
}

.status-badge.done{
  background:#00c853;
  color:#fff;

  box-shadow:
    0 0 18px rgba(0,200,83,.35);
}

/* =========================
   DETAIL
========================= */

.detail-box{
  margin-top:25px;

  background:rgba(255,255,255,.05);

  border-radius:20px;

  padding:22px;

  line-height:1.9;

  color:#eafcff;

  border:1px solid rgba(255,255,255,.05);
}

/* =========================
   URGENT
========================= */

.urgent{
  display:inline-flex;
  align-items:center;
  gap:8px;

  margin-top:20px;

  padding:10px 18px;

  border-radius:999px;

  background:#ff3d3d;

  color:#fff;

  font-size:13px;
  font-weight:700;

  box-shadow:
    0 0 20px rgba(255,0,0,.35);
}

/* =========================
   FOOTER
========================= */

.card-footer{
  margin-top:28px;

  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:15px;
  flex-wrap:wrap;
}

/* TIME */

.time{
  color:#bdefff;
  font-size:14px;
}

/* BUTTON */

.done-btn{
  border:none;

  padding:14px 24px;

  border-radius:16px;

  background:
    linear-gradient(
      135deg,
      #00e5ff,
      #00c853
    );

  color:#003344;

  font-size:15px;
  font-weight:700;

  cursor:pointer;

  transition:.3s;
}

.done-btn:hover{
  transform:scale(1.05);

  box-shadow:
    0 10px 25px rgba(0,255,200,.35);
}

/* =========================
   MOBILE
========================= */

@media(max-width:768px){

  .header h2{
    font-size:28px;
  }

  .top-tools{
    flex-direction:column;
    align-items:stretch;
  }

  .stats{
    width:100%;
  }

  .stat-card{
    flex:1;
  }

  .case-card{
    padding:24px;
  }

  .case-title{
    font-size:22px;
  }

  .card-footer{
    flex-direction:column;
    align-items:stretch;
  }

  .done-btn{
    width:100%;
  }

}

</style>
</head>

<body>

<div class="header">

  <h2>📂 เคสของฉัน</h2>

  <p>
    ติดตามและจัดการเคสที่คุณรับดูแลผู้สูงอายุ
  </p>

</div>

<div class="container">

<% let list = data || []; %>

<!-- TOP -->

<div class="top-tools">

  <a href="/volunteer" class="back-link">
    ← กลับหน้าเคสรอรับ
  </a>

  <div class="stats">

    <div class="stat-card">
      <div class="stat-title">
        เคสทั้งหมด
      </div>

      <div class="stat-value">
        <%= list.length %>
      </div>
    </div>

  </div>

</div>

<!-- EMPTY -->

<% if(list.length === 0){ %>

<div class="empty">
  🤍 ยังไม่มีเคสที่คุณรับไว้ในตอนนี้
</div>

<% } %>

<!-- CASE -->

<% list.forEach(row => { %>

<div class="case-card">

  <!-- TOP -->

  <div class="card-top">

    <div class="case-title">
      👵 <%= row.elder_name || "ผู้สูงอายุ" %>
    </div>

    <div class="status-badge <%= row.status %>">

      <%= row.status === "accepted"
          ? "กำลังดำเนินการ"
          : "เสร็จสิ้น" %>

    </div>

  </div>

  <!-- DETAIL -->



  <!-- URGENT -->

  <% if(row.urgency === "urgent"){ %>

    

  <% } %>

  <!-- FOOTER -->

  <div class="card-footer">

    <div class="time">

      📅
      <%= row.created_at
        ? new Date(row.created_at).toLocaleString("th-TH")
        : "-" %>

    </div>

    <% if(row.status !== "done"){ %>

    <form
      method="POST"
      action="/volunteer/done/<%= row.id %>"
    >

      <button class="done-btn">
        ✅ จบเคส
      </button>

    </form>

    <% } %>

  </div>

</div>

<% }) %>

</div>

</body>
</html>