<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>รายละเอียดเคสด่วน (AI) | Admin</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
*{
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  margin:0;
  background:#f4f6f9;
  display:flex;
  min-height:100vh;
  color:#333;
}

/* Sidebar */
.sidebar{
  width:240px;
  background:#111827;
  color:#fff;
  padding:25px 20px;
}

.sidebar h2{
  margin:0 0 30px;
  font-size:18px;
}

.sidebar a{
  display:block;
  padding:12px 15px;
  margin-bottom:8px;
  border-radius:8px;
  text-decoration:none;
  color:#cbd5e1;
  font-size:14px;
  transition:.2s;
}

.sidebar a:hover{
  background:#1f2937;
  color:#fff;
}

/* Main */
.main{
  flex:1;
  padding:35px;
}

.topbar{
  margin-bottom:25px;
}

.topbar h1{
  margin:0;
  font-size:22px;
}

.back-link{
  display:inline-block;
  margin-bottom:20px;
  text-decoration:none;
  font-size:14px;
  color:#2563eb;
}

.back-link:hover{
  text-decoration:underline;
}

/* Card */
.card{
  background:#fff;
  border-radius:14px;
  padding:25px;
  box-shadow:0 5px 20px rgba(0,0,0,0.05);
  margin-bottom:25px;
}

/* Info Grid */
.info-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
}

.info-box{
  background:#f9fafb;
  padding:18px;
  border-radius:12px;
}

.info-title{
  font-size:13px;
  color:#666;
}

.info-value{
  margin-top:6px;
  font-weight:500;
}

/* AI original message box */
.ai-message-box{
  background:#fef2f2;
  border:1px solid #fecaca;
  border-radius:12px;
  padding:18px;
  margin-top:20px;
}

.ai-message-box .label{
  font-size:13px;
  color:#991b1b;
  font-weight:600;
  margin-bottom:8px;
}

.ai-message-box .content{
  font-size:14px;
  line-height:1.6;
  color:#333;
}

/* Status */
.status{
  padding:5px 12px;
  border-radius:20px;
  font-size:12px;
  font-weight:500;
}

.status.accepted{
  background:#fef3c7;
  color:#92400e;
}

.status.done{
  background:#dcfce7;
  color:#166534;
}

.status.open{
  background:#fee2e2;
  color:#991b1b;
}

/* Risk badge */
.risk-badge{
  padding:5px 12px;
  border-radius:20px;
  font-size:12px;
  font-weight:600;
}

.risk-badge.emergency{
  background:#fee2e2;
  color:#991b1b;
}

.risk-badge.high{
  background:#ffedd5;
  color:#9a3412;
}

/* Chat */
.chat-box{
  max-height:450px;
  overflow-y:auto;
  padding-right:5px;
}

.message{
  max-width:70%;
  padding:12px 16px;
  border-radius:16px;
  margin:12px 0;
  font-size:14px;
  line-height:1.6;
}

.message small{
  display:block;
  margin-top:6px;
  font-size:11px;
  color:#777;
}

/* Left = ผู้สูงอายุ */
.left{
  background:#f1f5f9;
  border-top-left-radius:5px;
}

/* Right = อาสา */
.right{
  background:#2563eb;
  color:#fff;
  margin-left:auto;
  border-top-right-radius:5px;
}

.right small{
  color:#e0e7ff;
}
</style>
</head>

<body>

<div class="sidebar">
  <h2>🛠 SmartCompanion</h2>
  <a href="/admin">📋 เคสทั้งหมด</a>
  <a href="/admin/working">🟢 เคสกำลังทำ</a>
  <a href="/admin/volunteers">👥 อนุมัติอาสา</a>
  <a href="/admin/reports">📊 รายงาน</a>
  <a href="/logout">🚪 ออกจากระบบ</a>
</div>

<div class="main">

  <div class="topbar">
    <h1>🚨 รายละเอียดเคสด่วน (AI)</h1>
  </div>

  <a href="/admin/reports" class="back-link">← กลับหน้ารายงาน</a>

  <!-- INFO -->
  <div class="card">
    <div class="info-grid">

      <div class="info-box">
        <div class="info-title">ผู้สูงอายุ</div>
        <div class="info-value">
          <%= caseData.elderly_name || '-' %>
        </div>
      </div>

      <div class="info-box">
        <div class="info-title">อาสาที่รับเคส</div>
        <div class="info-value">
          <%= caseData.volunteer_name || 'ยังไม่มีอาสารับ' %>
        </div>
      </div>

      <div class="info-box">
        <div class="info-title">ระดับความเสี่ยง (AI)</div>
        <div class="info-value">
          <% if(caseData.risk === 'emergency'){ %>
            <span class="risk-badge emergency">🆘 EMERGENCY</span>
          <% } else if(caseData.risk === 'high'){ %>
            <span class="risk-badge high">🚨 HIGH</span>
          <% } else { %>
            <span class="risk-badge"><%= caseData.risk %></span>
          <% } %>
        </div>
      </div>

      <div class="info-box">
        <div class="info-title">สถานะเคส</div>
        <div class="info-value">
          <span class="status <%= caseData.status %>">
            <%= caseData.status === 'done' ? 'เสร็จสิ้น'
              : caseData.status === 'accepted' ? 'กำลังดำเนินการ'
              : 'รอรับเคส' %>
          </span>
        </div>
      </div>

      <div class="info-box">
        <div class="info-title">วันที่แจ้งเตือน</div>
        <div class="info-value">
          <%= caseData.created_at
              ? new Date(caseData.created_at).toLocaleString('th-TH')
              : '-' %>
        </div>
      </div>

    </div>

    <div class="ai-message-box">
      <div class="label">💬 ข้อความต้นเหตุที่ AI ตรวจพบ</div>
      <div class="content"><%= caseData.message || '-' %></div>
    </div>

  </div>

  <!-- CHAT -->
  <div class="card">
    <h3 style="margin-top:0;">💬 ประวัติการสนทนาหลังรับเคส</h3>

    <div class="chat-box">

      <% if(messages && messages.length > 0){ %>

        <% messages.forEach(msg=>{ %>

          <%
            let side = (msg.name === caseData.volunteer_name)
                       ? 'right'
                       : 'left';
          %>

          <div class="message <%= side %>">
            <b><%= msg.name %></b><br>
            <%= msg.message %>
            <small>
              <%= new Date(msg.created_at).toLocaleString('th-TH') %>
            </small>
          </div>

        <% }) %>

      <% } else { %>
        <p style="color:#777;">ยังไม่มีการสนทนาในเคสนี้</p>
      <% } %>

    </div>
  </div>

</div>

</body>
</html>
