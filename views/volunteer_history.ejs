<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>SmartCompanion | ประวัติงาน</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  min-height:100vh;
  background:linear-gradient(135deg,#071018,#0f2027,#1c3b4d);
  color:#fff;
}

/* HEADER */
.header{
  text-align:center;
  padding:30px;
  background:rgba(255,255,255,0.06);
  backdrop-filter:blur(12px);
}

.header h1{
  font-size:32px;
}

.header p{
  opacity:.8;
  margin-top:6px;
}

/* CONTAINER */
.container{
  max-width:1100px;
  margin:auto;
  padding:30px 20px;
}

/* BACK BUTTON */
.back-btn{
  display:inline-block;
  margin-bottom:20px;
  padding:10px 16px;
  border-radius:12px;
  text-decoration:none;
  color:#9ef7ff;
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.1);
  transition:.2s;
}

.back-btn:hover{
  transform:translateY(-2px);
  background:rgba(0,255,255,0.15);
}

/* STATS */
.stat-box{
  display:flex;
  justify-content:flex-end;
  gap:14px;
  margin-bottom:20px;
  flex-wrap:wrap;
}

.stat{
  background:rgba(255,255,255,0.08);
  padding:15px 20px;
  border-radius:14px;
  border:1px solid rgba(255,255,255,0.1);
}

.stat.urgent-stat{
  background:rgba(255,77,77,0.12);
  border:1px solid rgba(255,77,77,0.35);
}

.stat-title{
  font-size:12px;
  opacity:.7;
}

.stat-value{
  font-size:22px;
  font-weight:600;
}

.stat.urgent-stat .stat-value{
  color:#ff6b6b;
}

/* FILTER TABS */
.filter-box{
  display:flex;
  gap:10px;
  margin-bottom:20px;
  flex-wrap:wrap;
}

.filter-btn{
  padding:10px 18px;
  border-radius:14px;
  border:1px solid rgba(255,255,255,0.15);
  background:rgba(255,255,255,0.06);
  color:#fff;
  font-family:'Prompt',sans-serif;
  font-size:14px;
  cursor:pointer;
  transition:.2s;
}

.filter-btn:hover{
  transform:translateY(-2px);
  background:rgba(255,255,255,0.12);
}

.filter-btn.active{
  background:#00e5ff;
  color:#003344;
  border-color:#00e5ff;
  font-weight:600;
}

.filter-btn.active[data-filter="urgent"]{
  background:#ff4d4d;
  color:#3b0000;
  border-color:#ff4d4d;
}

/* EMPTY */
.empty{
  text-align:center;
  padding:60px;
  background:rgba(255,255,255,0.06);
  border-radius:18px;
}

/* CARD */
.card{
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:20px;
  padding:20px;
  margin-bottom:20px;
  transition:.2s;
}

.card:hover{
  transform:translateY(-4px);
}

/* HEADER CARD */
.card-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:10px;
  gap:10px;
  flex-wrap:wrap;
}

.case-title{
  font-size:20px;
  font-weight:600;
}

.case-id{
  font-size:12px;
  padding:4px 10px;
  background:rgba(255,255,255,0.12);
  border-radius:20px;
}

.header-badges{
  display:flex;
  align-items:center;
  gap:8px;
}

/* STATUS */
.badge{
  padding:6px 12px;
  border-radius:20px;
  font-size:12px;
  font-weight:600;
}

.done{ background:#00c853; color:#003322; }
.working{ background:#ffb300; color:#3b2f00; }
.pending{ background:#00e5ff; color:#003344; }

.badge.urgent-badge{
  background:#ff4d4d;
  color:#3b0000;
}

/* DETAIL */
.detail{
  margin-top:10px;
  padding:12px;
  background:rgba(0,0,0,0.2);
  border-radius:12px;
  font-size:14px;
}

/* CHAT */
.chat{
  margin-top:15px;
  padding:12px;
  background:rgba(0,0,0,0.25);
  border-radius:14px;
  max-height:200px;
  overflow:auto;
}

.msg{
  margin-bottom:10px;
  font-size:13px;
}

.msg b{
  color:#9ef7ff;
}

/* FOOTER */
.footer{
  display:flex;
  justify-content:space-between;
  margin-top:10px;
  font-size:12px;
  opacity:.8;
}

/* URGENCY BORDER */
.urgent{
  border-left:4px solid #ff4d4d;
}

.normal{
  border-left:4px solid #00e5ff;
}

</style>
</head>

<body>

<div class="header">
  <h1>📜 ประวัติงานอาสา</h1>
  <p>แสดงเคสที่เสร็จแล้วทั้งหมด</p>
</div>

<div class="container">

<!-- BACK BUTTON -->
<a href="/volunteer" class="back-btn">← กลับหน้าเคส</a>

<!-- STATS -->
<div class="stat-box">
  <div class="stat">
    <div class="stat-title">จำนวนเคสทั้งหมด</div>
    <div class="stat-value"><%= (data||[]).length %></div>
  </div>
  <div class="stat urgent-stat">
    <div class="stat-title">🚨 เคสด่วนของฉัน</div>
    <div class="stat-value"><%= (data||[]).filter(row => row.urgency === 'urgent').length %></div>
  </div>
</div>

<!-- FILTER TABS -->
<div class="filter-box">
  <button class="filter-btn active" data-filter="all" onclick="filterCases('all', this)">ทั้งหมด</button>
  <button class="filter-btn" data-filter="urgent" onclick="filterCases('urgent', this)">🚨 เคสด่วน (AI)</button>
  <button class="filter-btn" data-filter="normal" onclick="filterCases('normal', this)">📋 เคสปกติ</button>
</div>

<!-- EMPTY -->
<% if(!data || data.length === 0){ %>
  <div class="empty">🤍 ไม่มีประวัติงาน</div>
<% } %>

<!-- CARD LOOP -->
<% (data||[]).forEach((row,i)=>{ %>

<div class="card <%= row.urgency === 'urgent' ? 'urgent' : 'normal' %>" data-urgency="<%= row.urgency === 'urgent' ? 'urgent' : 'normal' %>">

  <!-- HEADER -->
  <div class="card-header">

    <div>
      <div class="case-title">👵 <%= row.elder_name || "ผู้สูงอายุ" %></div>
      <div class="case-id">CASE #<%= row.id || i+1 %></div>
    </div>

    <div class="header-badges">
      <% if(row.urgency === 'urgent'){ %>
        <div class="badge urgent-badge">🚨 เคสด่วน</div>
      <% } %>
      <div class="badge <%= row.status %>">
        <%= row.status === "done" ? "เสร็จสิ้น" : row.status %>
      </div>
    </div>

  </div>

  <!-- DETAIL -->
  <div class="detail">
    <%= row.detail || "ข้อมูลแชท" %>
  </div>

  <!-- CHAT -->
  <div class="chat">

    <% if(row.messages && row.messages.length){ %>
      <% row.messages.forEach(m=>{ %>
        <div class="msg">
          <b><%= m.name %>:</b> <%= m.message %>
        </div>
      <% }) %>
    <% } else { %>
      <div style="opacity:.6">ไม่มีข้อความ</div>
    <% } %>

  </div>

  <!-- FOOTER -->
  <div class="footer">
    <div>💬 <%= row.last_message || "-" %></div>
    <div>🕒 <%= row.completed_at ? new Date(row.completed_at).toLocaleString("th-TH") : "-" %></div>
  </div>

</div>

<% }) %>

<!-- EMPTY FILTER RESULT (shown by JS when a filter has no matches) -->
<div class="empty" id="emptyFilter" style="display:none">🤍 ไม่มีเคสในหมวดนี้</div>

</div>

<script>
function filterCases(type, btn){
  // toggle active button state
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  const cards = document.querySelectorAll('.card[data-urgency]');
  let visibleCount = 0;

  cards.forEach(card => {
    const match = (type === 'all') || (card.getAttribute('data-urgency') === type);
    card.style.display = match ? '' : 'none';
    if(match) visibleCount++;
  });

  const emptyFilter = document.getElementById('emptyFilter');
  if(emptyFilter){
    emptyFilter.style.display = (visibleCount === 0 && cards.length > 0) ? 'block' : 'none';
  }
}
</script>

</body>
</html>
