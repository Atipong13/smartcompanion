<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>SmartCompanion Reports</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  background:#0f172a;
  color:#fff;
  display:flex;
  min-height:100vh;
}

/* SIDEBAR */

.sidebar{
  width:260px;
  background:rgba(15,23,42,.95);
  backdrop-filter:blur(20px);
  border-right:1px solid rgba(255,255,255,.05);
  padding:30px 20px;
}

.logo{
  font-size:24px;
  font-weight:600;
  margin-bottom:40px;
}

.sidebar a{
  display:flex;
  align-items:center;
  gap:12px;
  color:#cbd5e1;
  text-decoration:none;
  padding:14px 16px;
  border-radius:16px;
  margin-bottom:10px;
  transition:.25s;
}

.sidebar a:hover{
  background:#2563eb;
  color:#fff;
  transform:translateX(4px);
}

/* MAIN */

.main{
  flex:1;
  padding:30px;
}

/* TOPBAR */

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30px;
}

.topbar h1{
  font-size:30px;
}

/* BUTTONS */

.export-box{
  display:flex;
  gap:12px;
}

.export-btn{
  padding:12px 18px;
  border-radius:14px;
  color:#fff;
  text-decoration:none;
  font-size:14px;
  font-weight:500;
  transition:.25s;
}

.export-btn:hover{
  transform:translateY(-2px);
}

.excel{
  background:#16a34a;
}

.pdf{
  background:#dc2626;
}

/* KPI */

.kpi-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
  gap:20px;
  margin-bottom:30px;
}

.kpi-card{
  background:linear-gradient(
    135deg,
    rgba(37,99,235,.95),
    rgba(59,130,246,.7)
  );

  border-radius:26px;
  padding:25px;
  position:relative;
  overflow:hidden;

  box-shadow:
    0 15px 40px rgba(37,99,235,.25);

  transition:.25s;
}

.kpi-card:hover{
  transform:translateY(-5px);
}

.kpi-card::before{
  content:'';
  position:absolute;
  width:160px;
  height:160px;
  background:rgba(255,255,255,.08);
  border-radius:50%;
  top:-50px;
  right:-50px;
}

.kpi-title{
  color:#dbeafe;
  font-size:14px;
}

.kpi-value{
  font-size:40px;
  font-weight:600;
  margin-top:10px;
}

/* GRID */

.grid{
  display:grid;
  grid-template-columns:2fr 1fr;
  gap:25px;
  margin-bottom:25px;
}

.card{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.06);
  backdrop-filter:blur(18px);

  border-radius:24px;
  padding:25px;
}

/* CHART */

.chart-title{
  margin-bottom:20px;
  font-size:18px;
}

/* TABLE */

.table-box{
  overflow:auto;
}

table{
  width:100%;
  border-collapse:collapse;
}

th{
  color:#94a3b8;
  text-align:left;
  padding:14px;
  font-size:13px;
  border-bottom:1px solid rgba(255,255,255,.08);
}

td{
  padding:16px 14px;
  font-size:14px;
  border-bottom:1px solid rgba(255,255,255,.05);
}

tr{
  transition:.2s;
}

tr:hover{
  background:rgba(255,255,255,.04);
}

/* STATUS */

.status{
  padding:7px 14px;
  border-radius:999px;
  font-size:12px;
  font-weight:600;
}

.status.accepted{
  background:#f59e0b33;
  color:#fbbf24;
}

.status.completed{
  background:#16a34a33;
  color:#4ade80;
}

.status.pending{
  background:#dc262633;
  color:#f87171;
}

/* LINK */

.detail-link{
  color:#60a5fa;
  text-decoration:none;
}

.detail-link:hover{
  text-decoration:underline;
}

/* ACTIVITY */

.activity-item{
  display:flex;
  align-items:center;
  gap:14px;
  margin-bottom:18px;
}

.activity-dot{
  width:12px;
  height:12px;
  border-radius:50%;
  background:#3b82f6;
}

.activity-content{
  font-size:14px;
  color:#cbd5e1;
}

/* MOBILE */

@media(max-width:1000px){

  .grid{
    grid-template-columns:1fr;
  }

  .sidebar{
    display:none;
  }

}

</style>
</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

  <div class="logo">
    🛠 SmartCompanion
  </div>

  <a href="/admin">📋 Dashboard</a>
  <a href="/admin/working">🟢 เคสกำลังทำ</a>
  <a href="/admin/volunteers">👥 อนุมัติอาสา</a>
  <a href="/admin/users">👤 ผู้ใช้</a>
  <a href="/admin/reports">📊 รายงาน</a>
  <a href="/logout">🚪 ออกจากระบบ</a>

</div>

<!-- MAIN -->

<div class="main">

  <!-- TOPBAR -->

  <div class="topbar">

    <h1>
      📊 Smart Analytics
    </h1>

    <div class="export-box">

      <a href="/admin/export/excel"
         class="export-btn excel">
         Export Excel
      </a>

      <a href="/admin/export/pdf"
         class="export-btn pdf">
         Export PDF
      </a>

    </div>

  </div>

  <!-- KPI -->

  <div class="kpi-grid">

    <div class="kpi-card">
      <div class="kpi-title">
        เคสทั้งหมด
      </div>

      <div class="kpi-value">
        <%= totalCases || 0 %>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">
        กำลังดำเนินการ
      </div>

      <div class="kpi-value">
        <%= workingCases || 0 %>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">
        เสร็จสิ้น
      </div>

      <div class="kpi-value">
        <%= doneCases || 0 %>
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">
        ผู้ใช้ทั้งหมด
      </div>

      <div class="kpi-value">
        <%= totalUsers || 0 %>
      </div>
    </div>

  </div>

  <!-- GRID -->

  <div class="grid">

    <!-- LEFT -->

    <div>

      <!-- CHART -->

      <div class="card">

        <div class="chart-title">
          📈 Analytics
        </div>

        <div id="lineChart"></div>

      </div>

      <br>

      <!-- TABLE -->

      <div class="card">

        <div class="chart-title">
          📋 ประวัติการดำเนินงานล่าสุด
        </div>

        <div class="table-box">

          <table>

            <tr>
              <th>#</th>
              <th>ผู้สูงอายุ</th>
              <th>อาสา</th>
              <th>รายละเอียด</th>
              <th>สถานะ</th>
              <th>วันที่</th>
            </tr>

            <% if(history && history.length > 0){ %>

              <% history.forEach((row,index)=>{ %>

                <tr
                  onclick="window.location='/admin/reports/<%= row.id %>'"
                  style="cursor:pointer;"
                >

                  <td><%= index + 1 %></td>

                  <td>
                    <%= row.elderly_name || '-' %>
                  </td>

                  <td>
                    <%= row.volunteer_name || '-' %>
                  </td>

                  <td>

                    <%= row.detail
                      ? row.detail.substring(0,40)
                      : '-' %>

                    <% if(row.detail && row.detail.length > 40){ %>
                      ...
                    <% } %>

                    <br><br>

                    <a
                      href="/admin/reports/<%= row.id %>"
                      class="detail-link"
                    >
                      ดูรายละเอียด
                    </a>

                  </td>

                  <td>

                    <span class="status <%= row.status %>">

                      <%= row.status === 'completed'
                        ? 'เสร็จสิ้น'
                        : row.status === 'accepted'
                        ? 'กำลังดำเนินการ'
                        : 'รอดำเนินการ' %>

                    </span>

                  </td>

                  <td>

                    <%= row.created_at
                      ? new Date(
                          row.created_at
                        ).toLocaleString()
                      : '-' %>

                  </td>

                </tr>

              <% }) %>

            <% } else { %>

              <tr>
                <td colspan="6">
                  ไม่มีข้อมูล
                </td>
              </tr>

            <% } %>

          </table>

        </div>

      </div>

    </div>

    <!-- RIGHT -->

    <div>

      <!-- DONUT -->

      <div class="card">

        <div class="chart-title">
          📊 Case Status
        </div>

        <div id="donutChart"></div>

      </div>

      <br>

      <!-- ACTIVITY -->

      <div class="card">

        <div class="chart-title">
          ⚡ Activity
        </div>

        <div class="activity-item">
          <div class="activity-dot"></div>
          <div class="activity-content">
            เคสทั้งหมด <%= totalCases %> เคส
          </div>
        </div>

        <div class="activity-item">
          <div class="activity-dot"></div>
          <div class="activity-content">
            อาสาสมัคร <%= totalVolunteers %> คน
          </div>
        </div>

        <div class="activity-item">
          <div class="activity-dot"></div>
          <div class="activity-content">
            ผู้สูงอายุ <%= totalElders %> คน
          </div>
        </div>

      </div>

    </div>

  </div>

</div>

<script>

/* LINE CHART */

const lineOptions = {

  series:[{
    name:'Cases',
    data:[
      <%= totalCases %>,
      <%= workingCases %>,
      <%= doneCases %>,
      <%= totalVolunteers %>,
      <%= totalElders %>
    ]
  }],

  chart:{
    type:'area',
    height:320,
    toolbar:{
      show:false
    }
  },

  theme:{
    mode:'dark'
  },

  colors:['#3b82f6'],

  dataLabels:{
    enabled:false
  },

  stroke:{
    curve:'smooth',
    width:4
  },

  fill:{
    type:'gradient',
    gradient:{
      shadeIntensity:1,
      opacityFrom:0.5,
      opacityTo:0.05
    }
  },

  xaxis:{
    categories:[
      'All Cases',
      'Working',
      'Done',
      'Volunteers',
      'Elders'
    ]
  }

};

new ApexCharts(
  document.querySelector("#lineChart"),
  lineOptions
).render();

/* DONUT */

const donutOptions = {

  series:[
    <%= workingCases || 0 %>,
    <%= doneCases || 0 %>
  ],

  labels:[
    'Working',
    'Completed'
  ],

  chart:{
    type:'donut',
    height:320
  },

  theme:{
    mode:'dark'
  },

  legend:{
    position:'bottom'
  }

};

new ApexCharts(
  document.querySelector("#donutChart"),
  donutOptions
).render();

</script>

</body>
</html>
