<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Analytics | SmartCompanion Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  background:#0f172a;
  color:#fff;
  display:flex;
  min-height:100vh;
}

a{ text-decoration:none; }

/* SIDEBAR */

.sidebar{
  width:260px;
  background:rgba(15,23,42,.95);
  border-right:1px solid rgba(255,255,255,.05);
  backdrop-filter:blur(18px);
  padding:30px 20px;
}

.logo{
  font-size:24px;
  font-weight:600;
  margin-bottom:40px;
}

.sidebar a{
  display:flex;
  align-items:center;
  gap:12px;
  color:#cbd5e1;
  text-decoration:none;
  padding:14px 16px;
  border-radius:16px;
  margin-bottom:10px;
  transition:.25s;
}

.sidebar a:hover{
  background:#2563eb;
  color:#fff;
  transform:translateX(4px);
}

.sidebar a.active{
  background:#2563eb;
  color:#fff;
}

/* MAIN */

.main{
  flex:1;
  padding:30px;
}

/* TOPBAR */

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:16px;
  margin-bottom:30px;
}

.topbar h1{
  font-size:30px;
}

.topbar-right{
  display:flex;
  align-items:center;
  gap:12px;
  flex-wrap:wrap;
}

/* FILTER */

.filter-select{
  padding:14px 18px;
  border:none;
  border-radius:18px;
  background:rgba(255,255,255,.06);
  color:#fff;
  font-size:14px;
  outline:none;
  cursor:pointer;
}

.filter-select option{
  background:#0f172a;
  color:#fff;
}

/* SEARCH */

.search-box{
  margin-bottom:25px;
}

.search-box input{
  width:100%;
  padding:14px 18px;
  border:none;
  border-radius:18px;
  background:rgba(255,255,255,.06);
  color:#fff;
  font-size:14px;
  outline:none;
}

.search-box input::placeholder{
  color:#94a3b8;
}

/* EXPORT BUTTONS */

.export-btn{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:13px 20px;
  border-radius:18px;
  font-size:14px;
  font-weight:500;
  border:none;
  cursor:pointer;
  transition:.25s;
  color:#fff;
}

.export-btn.excel{ background:#16a34a; }
.export-btn.excel:hover{ background:#15803d; }

.export-btn.pdf{ background:#dc2626; }
.export-btn.pdf:hover{ background:#b91c1c; }

/* KPI */

.kpi-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:30px;
}

.kpi-card{
  background:linear-gradient(
    135deg,
    rgba(37,99,235,.95),
    rgba(59,130,246,.7)
  );

  border-radius:24px;
  padding:25px;

  position:relative;
  overflow:hidden;

  box-shadow:
    0 15px 40px rgba(37,99,235,.25);

  transition:.25s;
}

.kpi-card:hover{
  transform:translateY(-5px);
}

.kpi-card::before{
  content:'';
  position:absolute;
  width:150px;
  height:150px;
  background:rgba(255,255,255,.08);
  border-radius:50%;
  top:-40px;
  right:-40px;
}

.kpi-card.urgent{
  background:linear-gradient(
    135deg,
    rgba(220,38,38,.95),
    rgba(239,68,68,.7)
  );
  box-shadow:0 15px 40px rgba(220,38,38,.25);
}

.kpi-title{
  color:#dbeafe;
  font-size:14px;
  position:relative;
  z-index:1;
}

.kpi-card.urgent .kpi-title{
  color:#fee2e2;
}

.kpi-value{
  font-size:38px;
  margin-top:10px;
  font-weight:600;
  position:relative;
  z-index:1;
}

.kpi-sub{
  font-size:12px;
  margin-top:6px;
  color:#dbeafe;
  position:relative;
  z-index:1;
  opacity:.85;
}

.kpi-card.urgent .kpi-sub{
  color:#fee2e2;
}

/* CONTENT GRID */

.content-grid{
  display:grid;
  grid-template-columns:1.6fr 1fr;
  gap:24px;
  align-items:start;
}

/* CARD */

.card{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.06);

  backdrop-filter:blur(18px);

  border-radius:24px;
  padding:25px;

  transition:.25s;
  margin-bottom:24px;
}

.card:hover{
  transform:translateY(-5px);
  box-shadow:0 20px 40px rgba(0,0,0,.25);
}

.card-title{
  font-size:17px;
  font-weight:600;
  margin-bottom:20px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.card-title .badge{
  font-size:12px;
  padding:6px 14px;
  border-radius:999px;
  background:#2563eb33;
  color:#60a5fa;
  font-weight:500;
}

/* TABLE */

.table-box{
  overflow-x:auto;
}

table{
  width:100%;
  border-collapse:collapse;
  font-size:13.5px;
}

th{
  text-align:left;
  color:#94a3b8;
  font-weight:500;
  padding:12px 10px;
  border-bottom:1px solid rgba(255,255,255,.08);
  white-space:nowrap;
}

td{
  padding:14px 10px;
  border-bottom:1px solid rgba(255,255,255,.06);
  vertical-align:top;
  color:#e2e8f0;
}

tr.row-link{
  cursor:pointer;
  transition:.2s;
}

tr.row-link:hover{
  background:rgba(255,255,255,.04);
}

/* ROLE / RISK / STATUS PILLS */

.role,
.risk,
.status{
  display:inline-block;
  padding:6px 14px;
  border-radius:999px;
  font-size:12px;
  font-weight:600;
  white-space:nowrap;
}

.elder{
  background:#2563eb33;
  color:#60a5fa;
}

.volunteer{
  background:#16a34a33;
  color:#4ade80;
}

.risk.high{
  background:#dc262633;
  color:#f87171;
}

.risk.medium{
  background:#f59e0b33;
  color:#fbbf24;
}

.risk.low{
  background:#16a34a33;
  color:#4ade80;
}

.status.completed{
  background:#16a34a33;
  color:#4ade80;
}

.status.accepted{
  background:#2563eb33;
  color:#60a5fa;
}

.status.pending{
  background:#f59e0b33;
  color:#fbbf24;
}

.detail-link{
  font-size:12px;
  color:#60a5fa;
  font-weight:500;
  display:inline-block;
  margin-top:8px;
}

.detail-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  padding:8px 16px;
  border-radius:12px;
  background:#2563eb33;
  color:#60a5fa;
  font-size:12.5px;
  font-weight:600;
  white-space:nowrap;
  transition:.2s;
}

.detail-btn:hover{
  background:#2563eb55;
  color:#93c5fd;
}

.detail-cell{
  text-align:center;
}

.empty-row td{
  text-align:center;
  color:#94a3b8;
  padding:40px 0;
}

/* AI URGENT LIST */

.ai-item{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
  padding:14px 0;
  border-bottom:1px solid rgba(255,255,255,.06);
}

.ai-item:last-child{ border-bottom:none; }

.ai-item .name{
  font-weight:600;
  font-size:14px;
}

.ai-item .detail{
  font-size:12.5px;
  color:#94a3b8;
  margin-top:4px;
  line-height:1.6;
}

/* ACTIVITY */

.activity-item{
  display:flex;
  align-items:center;
  gap:12px;
  padding:12px 0;
  border-bottom:1px solid rgba(255,255,255,.06);
}

.activity-item:last-child{ border-bottom:none; }

.activity-dot{
  width:9px;
  height:9px;
  border-radius:50%;
  background:#3b82f6;
  flex-shrink:0;
}

.activity-dot.red{ background:#ef4444; }

.activity-content{
  font-size:14px;
  color:#e2e8f0;
}

/* EMPTY */

.empty{
  text-align:center;
  margin-top:100px;
  color:#94a3b8;
  font-size:18px;
}

/* MOBILE */

@media(max-width:1000px){

  .sidebar{
    display:none;
  }

  .content-grid{
    grid-template-columns:1fr;
  }

}

</style>
</head><body>

<!-- SIDEBAR -->

<div class="sidebar">

  <div class="logo">🛠 SmartCompanion</div>

  <a href="/admin">📋 Dashboard</a>
  <a href="/admin/working">🟢 เคสกำลังทำ</a>
  <a href="/admin/volunteers">👥 อนุมัติอาสา</a>
  <a href="/admin/users">👤 ผู้ใช้</a>
  <a href="/admin/reports" class="active">📊 รายงาน</a>
  <a href="/logout">🚪 ออกจากระบบ</a>

</div>

<!-- MAIN -->

<div class="main">

  <!-- TOPBAR -->

  <div class="topbar">

    <h1>📊 Smart Analytics</h1>

    <div class="topbar-right">

      <form method="GET">
        <select name="filter" class="filter-select" onchange="this.form.submit()">
          <option value="all"   <%= filter=="all"   ? "selected" : "" %>>ทั้งหมด</option>
          <option value="day"   <%= filter=="day"   ? "selected" : "" %>>รายวัน</option>
          <option value="month" <%= filter=="month" ? "selected" : "" %>>รายเดือน</option>
          <option value="year"  <%= filter=="year"  ? "selected" : "" %>>รายปี</option>
        </select>
      </form>

      <a href="/admin/export/excel?filter=<%= filter %>" class="export-btn excel">⬇ Excel</a>
      <a href="/admin/export/pdf?filter=<%= filter %>" class="export-btn pdf">⬇ PDF</a>

    </div>

  </div>

  <!-- KPI -->

  <div class="kpi-grid">

    <div class="kpi-card">
      <div class="kpi-title">เคสทั้งหมด</div>
      <div class="kpi-value"><%= totalCases || 0 %></div>
    </div>

    <div class="kpi-card urgent">
      <div class="kpi-title">🚨 เคสด่วน (AI)</div>
      <div class="kpi-value"><%= highRiskCases || 0 %></div>
      <div class="kpi-sub">ตรวจพบความเสี่ยงสูงโดย AI</div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">กำลังดำเนินการ</div>
      <div class="kpi-value"><%= workingCases || 0 %></div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">เสร็จสิ้น</div>
      <div class="kpi-value"><%= doneCases || 0 %></div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">ผู้ใช้ทั้งหมด</div>
      <div class="kpi-value"><%= totalUsers || 0 %></div>
    </div>

  </div>

  <!-- CONTENT GRID -->

  <div class="content-grid">

    <!-- LEFT -->

    <div>

      <!-- CHART -->

      <div class="card">
        <div class="card-title">
          <span>📈 Analytics Overview</span>
          <span class="badge"><%= filter === 'all' ? 'ทั้งหมด' : filter === 'day' ? 'รายวัน' : filter === 'month' ? 'รายเดือน' : 'รายปี' %></span>
        </div>
        <div id="lineChart"></div>
      </div>

      <!-- TABLE -->

      <div class="card">

        <div class="card-title">
          <span>📋 ประวัติการดำเนินงานล่าสุด</span>
        </div>

        <div class="table-box">

          <table>

            <tr>
              <th>#</th>
              <th>ผู้สูงอายุ</th>
              <th>อาสา</th>
              <th class="detail-cell">รายละเอียด</th>
              <th>สถานะ</th>
              <th>วันที่</th>
            </tr>

            <% if(history && history.length > 0){ %>

              <% history.forEach((row,index)=>{ %>

                <tr class="row-link" onclick="window.location='/admin/reports/<%= row.id %>'">

                  <td><%= index + 1 %></td>

                  <td><%= row.elderly_name || '-' %></td>

                  <td><%= row.volunteer_name || '-' %></td>

                  <td class="detail-cell">
                    <a href="/admin/reports/<%= row.id %>"
                       onclick="event.stopPropagation()"
                       class="detail-btn">
                      🔍 ดูรายละเอียด
                    </a>
                  </td>

                  <td>
                    <span class="status <%= row.status %>">
                      <%= row.status === 'completed' ? 'เสร็จสิ้น'
                        : row.status === 'accepted'  ? 'กำลังดำเนินการ'
                        : 'รอดำเนินการ' %>
                    </span>
                  </td>

                  <td>
                    <%= row.created_at ? new Date(row.created_at).toLocaleString('th-TH') : '-' %>
                  </td>

                </tr>

              <% }) %>

            <% } else { %>

              <tr class="empty-row">
                <td colspan="6">ไม่มีข้อมูลในช่วงที่เลือก</td>
              </tr>

            <% } %>

          </table>

        </div>

      </div>

    </div>

    <!-- RIGHT -->

    <div>

      <!-- DONUT -->

      <div class="card">
        <div class="card-title"><span>📊 Case Status</span></div>
        <div id="donutChart"></div>
      </div>

      <!-- AI HIGH RISK LIST -->

      <div class="card">
        <div class="card-title">
          <span>🚨 เคสด่วนที่ AI ตรวจพบ</span>
          <span class="badge"><%= highRiskCases || 0 %> เคส</span>
        </div>

        <% if(typeof highRiskList !== 'undefined' && highRiskList && highRiskList.length > 0){ %>

          <% highRiskList.forEach(function(item){ %>
            <div class="ai-item">
              <div>
                <div class="name"><%= item.elderly_name || item.name || 'ไม่ระบุชื่อ' %></div>
                <div class="detail">
                  <%= item.detail ? item.detail.substring(0,60) : (item.message ? item.message.substring(0,60) : 'ไม่มีรายละเอียดเพิ่มเติม') %><%= ((item.detail && item.detail.length > 60) || (item.message && item.message.length > 60)) ? '...' : '' %>
                </div>
                <% if(item.risk=="emergency"){ %>
                  <span class="risk emergency">🆘 EMERGENCY</span>
                <% } else { %>
                  <span class="risk high">HIGH</span>
                <% } %>
              </div>
              <a href="/admin/case-report/<%= item.id %>" class="detail-btn">
                🔍 ดูรายละเอียด
              </a>
            </div>
          <% }) %>

        <% } else { %>

          <div class="activity-content" style="color:#94a3b8; padding:14px 0;">
            ไม่มีเคสด่วนในขณะนี้ 🎉
          </div>

        <% } %>

      </div>

      <!-- ACTIVITY -->

      <div class="card">
        <div class="card-title"><span>⚡ Activity</span></div>

        <div class="activity-item">
          <div class="activity-dot"></div>
          <div class="activity-content">เคสทั้งหมด <%= totalCases || 0 %> เคส</div>
        </div>

        <div class="activity-item">
          <div class="activity-dot red"></div>
          <div class="activity-content">🚨 เคสด่วน <%= highRiskCases || 0 %> เคส</div>
        </div>

        <div class="activity-item">
          <div class="activity-dot"></div>
          <div class="activity-content">อาสาสมัคร <%= totalVolunteers || 0 %> คน</div>
        </div>

        <div class="activity-item">
          <div class="activity-dot"></div>
          <div class="activity-content">ผู้สูงอายุ <%= totalElders || 0 %> คน</div>
        </div>

      </div>

    </div>

  </div>

</div>

<script>


const serverData = document.getElementById('server-data').dataset;

const totalCases       = Number(serverData.totalCases) || 0;
const workingCases     = Number(serverData.workingCases) || 0;
const doneCases        = Number(serverData.doneCases) || 0;
const totalVolunteers  = Number(serverData.totalVolunteers) || 0;
const totalElders      = Number(serverData.totalElders) || 0;
const highRiskCases    = Number(serverData.highRiskCases) || 0;

/* ===== LINE CHART ===== */

const lineOptions = {

  series:[{
    name:'จำนวน',
    data:[ totalCases, workingCases, doneCases, totalVolunteers, totalElders ]
  }],

  chart:{
    type:'area',
    height:300,
    toolbar:{ show:false },
    background:'transparent',
    fontFamily:'Prompt, sans-serif'
  },

  theme:{ mode:'dark' },

  colors:['#3b82f6'],

  dataLabels:{ enabled:false },

  stroke:{ curve:'smooth', width:4 },

  fill:{
    type:'gradient',
    gradient:{ shadeIntensity:1, opacityFrom:0.5, opacityTo:0.05 }
  },

  grid:{ borderColor:'rgba(255,255,255,.08)' },

  xaxis:{
    categories:['เคสทั้งหมด','กำลังดำเนินการ','เสร็จสิ้น','อาสาสมัคร','ผู้สูงอายุ'],
    labels:{ style:{ colors:'#94a3b8' } }
  },

  yaxis:{
    labels:{ style:{ colors:'#94a3b8' } }
  }

};

new ApexCharts(document.querySelector("#lineChart"), lineOptions).render();

/* ===== DONUT ===== */

const donutOptions = {

  series:[ workingCases, doneCases, highRiskCases ],

  labels:[ 'กำลังดำเนินการ', 'เสร็จสิ้น', 'เคสด่วน (AI)' ],

  chart:{
    type:'donut',
    height:300,
    background:'transparent',
    fontFamily:'Prompt, sans-serif'
  },

  theme:{ mode:'dark' },

  colors:['#3b82f6','#22c55e','#ef4444'],

  legend:{
    position:'bottom',
    labels:{ colors:'#94a3b8' }
  },

  dataLabels:{
    style:{ colors:['#fff'] }
  }

};

new ApexCharts(document.querySelector("#donutChart"), donutOptions).render();

</script>

</body>
</html>
