
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>อนุมัติอาสา | SmartCompanion</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Prompt',sans-serif;
}

body{
  background:#0f172a;
  color:#fff;
  display:flex;
  min-height:100vh;
}

/* SIDEBAR */

.sidebar{
  width:260px;
  background:rgba(15,23,42,.95);
  border-right:1px solid rgba(255,255,255,.05);
  backdrop-filter:blur(18px);
  padding:30px 20px;
}

.logo{
  font-size:24px;
  font-weight:600;
  margin-bottom:40px;
}

.sidebar a{
  display:flex;
  align-items:center;
  gap:12px;
  color:#cbd5e1;
  text-decoration:none;
  padding:14px 16px;
  border-radius:16px;
  margin-bottom:10px;
  transition:.25s;
}

.sidebar a:hover{
  background:#2563eb;
  color:#fff;
  transform:translateX(4px);
}

/* MAIN */

.main{
  flex:1;
  padding:30px;
}

/* TOPBAR */

.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30px;
}

.topbar h1{
  font-size:30px;
}

/* SEARCH */

.search-box{
  margin-bottom:25px;
}

.search-box input{
  width:100%;
  padding:14px 18px;
  border:none;
  border-radius:18px;
  background:rgba(255,255,255,.06);
  color:#fff;
  outline:none;
  font-size:14px;
}

.search-box input::placeholder{
  color:#94a3b8;
}

/* KPI */

.kpi-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:30px;
}

.kpi-card{
  background:linear-gradient(
    135deg,
    rgba(37,99,235,.95),
    rgba(59,130,246,.7)
  );

  border-radius:24px;
  padding:25px;

  position:relative;
  overflow:hidden;

  box-shadow:
    0 15px 40px rgba(37,99,235,.25);

  transition:.25s;
}

.kpi-card:hover{
  transform:translateY(-5px);
}

.kpi-card::before{
  content:'';
  position:absolute;
  width:150px;
  height:150px;
  background:rgba(255,255,255,.08);
  border-radius:50%;
  top:-40px;
  right:-40px;
}

.kpi-title{
  color:#dbeafe;
  font-size:14px;
}

.kpi-value{
  font-size:40px;
  margin-top:10px;
  font-weight:600;
}

/* GRID */

.cards-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(340px,1fr));
  gap:24px;
}

/* CARD */

.card{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.06);

  backdrop-filter:blur(18px);

  border-radius:24px;
  padding:25px;

  transition:.25s;
}

.card:hover{
  transform:translateY(-5px);
  box-shadow:0 20px 40px rgba(0,0,0,.25);
}

/* TOP */

.user-top{
  display:flex;
  align-items:center;
  gap:16px;
  margin-bottom:20px;
}

.avatar{
  width:70px;
  height:70px;
  border-radius:50%;

  background:linear-gradient(
    135deg,
    #3b82f6,
    #60a5fa
  );

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:26px;
  font-weight:600;
}

.user-info h3{
  margin-bottom:6px;
}

.user-info p{
  color:#94a3b8;
  font-size:13px;
}

/* DETAILS */

.details{
  line-height:2;
  color:#cbd5e1;
  font-size:14px;
  margin-top:15px;
}

/* SKILL */

.skill{
  display:inline-block;
  margin-top:14px;
  padding:6px 14px;
  border-radius:999px;

  background:#2563eb33;
  color:#60a5fa;

  font-size:12px;
  font-weight:600;
}

/* BUTTONS */

.btns{
  display:flex;
  gap:12px;
  margin-top:24px;
}

.btn{
  flex:1;
  border:none;
  padding:13px;
  border-radius:14px;
  cursor:pointer;
  font-size:14px;
  font-weight:500;
  transition:.25s;
}

.approve{
  background:#16a34a;
  color:#fff;
}

.approve:hover{
  background:#15803d;
}

.reject{
  background:#dc2626;
  color:#fff;
}

.reject:hover{
  background:#b91c1c;
}

/* EMPTY */

.empty{
  text-align:center;
  margin-top:100px;
  color:#94a3b8;
  font-size:18px;
}

/* MOBILE */

@media(max-width:1000px){

  .sidebar{
    display:none;
  }

}

</style>
</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

  <div class="logo">
    🛠 SmartCompanion
  </div>

  <a href="/admin">📋 Dashboard</a>
  <a href="/admin/working">🟢 เคสกำลังทำ</a>
  <a href="/admin/volunteers">👥 อนุมัติอาสา</a>
  <a href="/admin/users">👤 จัดการผู้ใช้</a>
  <a href="/admin/reports">📊 รายงาน</a>
  <a href="/logout">🚪 ออกจากระบบ</a>

</div>

<!-- MAIN -->

<div class="main">

  <!-- TOPBAR -->

  <div class="topbar">

    <h1>
      🧑‍🤝‍🧑 Volunteer Approval
    </h1>

  </div>

  <!-- SEARCH -->

  <div class="search-box">

    <input
      type="text"
      id="searchInput"
      placeholder="ค้นหาอาสาสมัคร..."
    >

  </div>

  <!-- KPI -->

  <div class="kpi-grid">

    <div class="kpi-card">

      <div class="kpi-title">
        อาสารออนุมัติ
      </div>

      <div class="kpi-value">
        <%= volunteers.length %>
      </div>

    </div>

  </div>

  <!-- EMPTY -->

  <% if(volunteers.length === 0){ %>

    <div class="empty">
      ไม่มีอาสารออนุมัติ
    </div>

  <% } %>

  <!-- CARDS -->

  <div class="cards-grid" id="cardsGrid">

    <% volunteers.forEach(v=>{ %>

      <div
        class="card volunteer-card"
        data-name="<%= v.name.toLowerCase() %>"
      >

        <!-- TOP -->

        <div class="user-top">

          <div class="avatar">
            <%= v.name.charAt(0) %>
          </div>

          <div class="user-info">

            <h3>
              <%= v.name %>
            </h3>

            <p>
              Volunteer ID:
              <%= v.id %>
            </p>

            <span class="skill">
              อาสาสมัคร
            </span>

          </div>

        </div>

        <!-- DETAILS -->

        <div class="details">

          📞 โทร:
          <%= v.phone || '-' %>

          <br>

          📍 พื้นที่:
          <%= v.area || '-' %>

          <br>

          🎂 อายุ:
          <%= v.age || '-' %>

          <br>

          💪 ความสามารถ:
          <%= v.skill || '-' %>

          <br>

          📝 ประสบการณ์:
          <%= v.experience || '-' %>

        </div>

        <!-- BUTTONS -->

        <div class="btns">

          <form
            action="/admin/approve/<%= v.id %>"
            method="POST"
            style="flex:1;"
          >

            <button
              type="submit"
              class="btn approve"
            >
              อนุมัติ
            </button>

          </form>

          <form
            action="/admin/reject/<%= v.id %>"
            method="POST"
            style="flex:1;"
          >

            <button
              type="submit"
              class="btn reject"
              onclick="return confirm(
                'ต้องการปฏิเสธอาสาคนนี้หรือไม่?'
              )"
            >
              ปฏิเสธ
            </button>

          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>

<script>

/* SEARCH */

const searchInput =
document.getElementById('searchInput');

const cards =
document.querySelectorAll('.volunteer-card');

searchInput.addEventListener('keyup',()=>{

  const keyword =
  searchInput.value.toLowerCase();

  cards.forEach(card=>{

    const name =
    card.dataset.name;

    if(name.includes(keyword)){

      card.style.display='block';

    }else{

      card.style.display='none';

    }

  });

});

</script>

</body>
</html>
```
